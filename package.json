{
  "name": "nexter-ui-component",
  "version": "1.0.0",
  "description": "Nexter Design System — React component library. 40+ accessible, token-driven components.",
  "author": "Nirmal Kavaiya <nirmalkavaiya@users.noreply.github.com>",
  "license": "MIT",
  "homepage": "https://github.com/nirmalkavaiya/Nexter-Ui-Component#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nirmalkavaiya/Nexter-Ui-Component.git"
  },
  "bugs": {
    "url": "https://github.com/nirmalkavaiya/Nexter-Ui-Component/issues"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "nexter",
    "wordpress",
    "admin",
    "dashboard",
    "button",
    "modal",
    "dropdown",
    "datepicker",
    "colorpicker",
    "accessible"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.1.5",
    "chromatic": "^16.6.3",
    "jsdom": "^24.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "^8.6.18",
    "vite": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
