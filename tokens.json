{
  "$schema": "https://raw.githubusercontent.com/tokens-studio/figma-plugin/main/token.schema.json",
  "version": "1.0.0",
  "meta": {
    "library": "nexter-ui-component",
    "description": "Flat design token reference for Figma / Tokens Studio sync"
  },
  "color": {
    "brand": {
      "100": { "$value": "hsl(221 100% 97%)", "$type": "color" },
      "200": { "$value": "hsl(221 96% 93%)", "$type": "color" },
      "300": { "$value": "hsl(221 93% 85%)", "$type": "color" },
      "400": { "$value": "hsl(221 87% 73%)", "$type": "color" },
      "500": { "$value": "hsl(221 83% 53%)", "$type": "color" },
      "600": { "$value": "hsl(221 72% 40%)", "$type": "color" },
      "700": { "$value": "hsl(221 68% 32%)", "$type": "color" },
      "800": { "$value": "hsl(221 64% 24%)", "$type": "color" },
      "900": { "$value": "hsl(221 60% 18%)", "$type": "color" },
      "accent": { "$value": "hsl(244 75% 57%)", "$type": "color" },
      "soft":   { "$value": "hsl(244 75% 95%)", "$type": "color" }
    },
    "semantic": {
      "primary":            { "$value": "hsl(var(--nxp-primary))",   "$type": "color" },
      "primary-foreground": { "$value": "hsl(var(--nxp-primary-foreground))", "$type": "color" },
      "secondary":          { "$value": "hsl(var(--nxp-secondary))", "$type": "color" },
      "secondary-foreground":{ "$value": "hsl(var(--nxp-secondary-foreground))", "$type": "color" },
      "background":         { "$value": "hsl(var(--nxp-background))","$type": "color" },
      "foreground":         { "$value": "hsl(var(--nxp-foreground))", "$type": "color" },
      "card":               { "$value": "hsl(var(--nxp-card))",       "$type": "color" },
      "card-foreground":    { "$value": "hsl(var(--nxp-card-foreground))", "$type": "color" },
      "muted":              { "$value": "hsl(var(--nxp-muted))",      "$type": "color" },
      "muted-foreground":   { "$value": "hsl(var(--nxp-muted-foreground))", "$type": "color" },
      "accent":             { "$value": "hsl(var(--nxp-accent))",     "$type": "color" },
      "accent-foreground":  { "$value": "hsl(var(--nxp-accent-foreground))", "$type": "color" },
      "border":             { "$value": "hsl(var(--nxp-border))",     "$type": "color" },
      "input":              { "$value": "hsl(var(--nxp-input))",      "$type": "color" },
      "ring":               { "$value": "hsl(var(--nxp-ring))",       "$type": "color" }
    },
    "status": {
      "destructive":            { "$value": "hsl(var(--nxp-destructive))", "$type": "color" },
      "destructive-foreground": { "$value": "hsl(var(--nxp-destructive-foreground))", "$type": "color" },
      "success":                { "$value": "hsl(var(--nxp-success))",     "$type": "color" },
      "success-foreground":     { "$value": "hsl(var(--nxp-success-foreground))", "$type": "color" },
      "warning":                { "$value": "hsl(var(--nxp-warning))",     "$type": "color" },
      "warning-foreground":     { "$value": "hsl(var(--nxp-warning-foreground))", "$type": "color" },
      "info":                   { "$value": "hsl(var(--nxp-info))",        "$type": "color" },
      "info-foreground":        { "$value": "hsl(var(--nxp-info-foreground))", "$type": "color" }
    }
  },
  "spacing": {
    "0":  { "$value": "0px",   "$type": "spacing" },
    "1":  { "$value": "4px",   "$type": "spacing" },
    "2":  { "$value": "8px",   "$type": "spacing" },
    "3":  { "$value": "12px",  "$type": "spacing" },
    "4":  { "$value": "16px",  "$type": "spacing" },
    "5":  { "$value": "20px",  "$type": "spacing" },
    "6":  { "$value": "24px",  "$type": "spacing" },
    "8":  { "$value": "32px",  "$type": "spacing" },
    "10": { "$value": "40px",  "$type": "spacing" },
    "12": { "$value": "48px",  "$type": "spacing" },
    "14": { "$value": "56px",  "$type": "spacing" },
    "16": { "$value": "64px",  "$type": "spacing" }
  },
  "borderRadius": {
    "none": { "$value": "0px",    "$type": "borderRadius" },
    "sm":   { "$value": "4px",    "$type": "borderRadius" },
    "md":   { "$value": "6px",    "$type": "borderRadius" },
    "lg":   { "$value": "12px",   "$type": "borderRadius" },
    "xl":   { "$value": "16px",   "$type": "borderRadius" },
    "2xl":  { "$value": "24px",   "$type": "borderRadius" },
    "full": { "$value": "9999px", "$type": "borderRadius" }
  },
  "typography": {
    "fontFamily": {
      "sans": { "$value": "Inter, system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "JetBrains Mono, Fira Code, monospace",        "$type": "fontFamily" }
    },
    "fontSize": {
      "xs":   { "$value": "11px", "$type": "fontSize" },
      "sm":   { "$value": "12px", "$type": "fontSize" },
      "base": { "$value": "13px", "$type": "fontSize" },
      "md":   { "$value": "14px", "$type": "fontSize" },
      "lg":   { "$value": "16px", "$type": "fontSize" },
      "xl":   { "$value": "18px", "$type": "fontSize" },
      "2xl":  { "$value": "20px", "$type": "fontSize" },
      "3xl":  { "$value": "24px", "$type": "fontSize" }
    },
    "fontWeight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px 0 rgba(0,0,0,0.05)", "$type": "shadow" },
    "md": { "$value": "0 2px 8px rgba(0,0,0,0.08), 0 1px 2px rgba(0,0,0,0.04)", "$type": "shadow" },
    "lg": { "$value": "0 8px 24px rgba(0,0,0,0.10), 0 2px 6px rgba(0,0,0,0.06)", "$type": "shadow" },
    "xl": { "$value": "0 16px 48px rgba(0,0,0,0.14), 0 4px 12px rgba(0,0,0,0.08)", "$type": "shadow" }
  }
}
